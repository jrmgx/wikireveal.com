{% extends 'base.html.twig' %}
{% block style %}
    <style>
        html, body { font-family: monospace !important; font-size: 110% }
    </style>
{% endblock %}

{% block body %}
    <section class="wz-section">
        <h1>
            {{ 'main.title'|trans }}
            <small>{{ 'main.sub_title'|trans }}</small>
        </h1>
        <div style="font-weight: bold">
            {{ 'main.description'|trans }}<br>
            {{ 'main.frequency'|trans }}
        </div>
        <hr>
        <div>
            {{ 'archives.promo'|trans }}<br>
            <a href="https://apps.apple.com/app/apple-store/id6766313023?pt=979843&ct=wikireveal.com&mt=8">
                <img src="/{{ asset_version_major }}/appstore.svg" alt="App Store"
                     style="width:200px;margin-top: 1rem;"
                />
            </a>
        </div>
        <div>
            <h2>{{ 'archives.title'|trans }}</h2>
            <p>{{ 'archives.click_to_see'|trans }}</p>
            <ul>
                {% set prevMonth = '' %}
                {% for archive in archives %}
                    {% if prevMonth != archive.date|date('m') %}
                    {% set prevMonth = archive.date|date('m') %}
            </ul>
            <h3>{{ archive.date|date('Y-m') }}</h3>
            <ul>
                {% endif %}
                <li>
                    <a href="{{ archive.url }}">{{ archive.date|date('Y-m-d') }}</a>
                    –
                    {{ 'archives.subject'|trans }}
                    <span class="wz-secret">{{ archive.subject }}</span>
                </li>
                {% endfor %}
            </ul>
        </div>
    </section>
    <script>
      (function () {
        document.querySelectorAll('.wz-secret').forEach((element) => {
          element.addEventListener('click', (event) => {
            event.preventDefault();
            event.target.classList.remove('wz-secret');
          });
        });
      })();
    </script>
{% endblock %}

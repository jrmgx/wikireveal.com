{% extends 'base.html.twig' %}
{% block style %}
    <style>
        html, body { font-family: monospace !important; font-size: 110% }
    </style>
{% endblock %}
{% block body %}
    <section class="wz-section">
        <h1>
            WikiReveal
            <small>Reveal the Wikipedia Page Behind the Redacted Words</small>
        </h1>
        <div style="font-weight: bold">
            WikiReveal is a daily browser game where the player have
            to determine the subject of a random obfuscated Wikipedia article.<br>
            A new puzzle will be available every day at 3:00 AM UTC.
        </div>
        <hr>
        <div>
            <strong>NEW:</strong> Get it on the App Store<br>
            <a href="https://apps.apple.com/app/apple-store/id6766313023?pt=979843&ct=wikireveal.com&mt=8">
                <img src="/{{ asset_version_major }}/appstore.svg" alt="App Store"
                     style="width:200px;margin-top: 1rem;"
                />
            </a>
        </div>
        <div>
            <h2>Available languages</h2>
            <ul>
                {% for lang, language in languages %}
                <li>
                    <a href="{{ path('app_index_wikireveal', {'_locale': lang}) }}">{{ language }}</a>
                    <small>(<a href="{{ path('app_index_archive', {'_locale': lang}) }}">{{ 'archives.title'|trans(locale=lang)|lower }}</a>)</small>
                </li>
                {% endfor %}
            </ul>
        </div>
        <div>
            <h2>How to Play</h2>
            <p>
                To win, you have to figure out the title of the article.<br>
                Type a word into the input box and press Enter or the button.
                All occurrences of that word will be revealed in the article.
            </p>
            <h2>Tips</h2>
            <ul>
                <li>Each guess must be one word only (multiple words will not work)</li>
                <li>Guesses are case-insensitive, and letters with diacritics (é, ü, etc) are considered to not have those diacritics</li>
                <li>
                    <a href="https://donate.wikimedia.org/wiki/Special:FundraiserRedirector?utm_source=donate&utm_medium=sidebar&utm_campaign=C13_en.wikipedia.org&uselang=en" target="_blank">
                        Donations to Wikipedia are encouraged
                    </a>
                </li>
            </ul>
            <h2>Privacy</h2>
            <p>
                No data are collected at all.
            </p>
        </div>
    </section>
{% endblock %}
